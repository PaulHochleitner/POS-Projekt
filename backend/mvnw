#!/bin/sh
# Maven Wrapper - delegates to maven-wrapper.jar with Java 21
JAVA_HOME="${JAVA_HOME:-C:/Program Files/Java/jdk-21}"
exec "$JAVA_HOME/bin/java" \
  -Dmaven.multiModuleProjectDirectory="$(cd "$(dirname "$0")" && pwd)" \
  -cp "$(cd "$(dirname "$0")" && pwd)/.mvn/wrapper/maven-wrapper.jar" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
